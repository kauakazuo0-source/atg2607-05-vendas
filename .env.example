# -----------------------------------------------------------------------------
# ARQUIVO DE EXEMPLO DE CONFIGURAÇÃO (.env.example)
# Copie este arquivo para um novo arquivo chamado `.env` no mesmo diretório
# e insira os valores reais correspondentes para produção/desenvolvimento.
# NUNCA comite o arquivo `.env` real no controle de versão!
# -----------------------------------------------------------------------------

# Configuração de Ambiente
NODE_ENV=production
PORT=3000

# Exemplo de credenciais para Integração de Pagamento (ex: Stripe, MercadoPago)
GATEWAY_API_KEY=sua_chave_de_api_aqui
GATEWAY_PUBLIC_KEY=sua_chave_publica_aqui

# Exemplo de serviço de E-mail (ex: SendGrid, Resend)
EMAIL_SERVICE_API_KEY=sua_chave_de_api_de_email_aqui
EMAIL_FROM_ADDRESS=contato@suadominio.com

# Analytics e Rastreamento
ANALYTICS_ID=UA-XXXXXXX-Y
